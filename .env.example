# ── OpenAI ──
OPENAI_API_KEY=sk-proj-...

# ── OpenRouter (오픈소스 모델) ──
OPENROUTER_API_KEY=sk-or-...

# ── 레거시 모델 설정 (티어 미사용 시 폴백) ──
MODEL_PROVIDER=openrouter
MODEL_NAME=deepseek/deepseek-v3.2

# ── 멀티티어 모델 설정 (오픈소스 via OpenRouter) ──
# Strong 티어 (코드 생성 등 고성능 작업)
STRONG_MODEL=qwen/qwen3-coder
STRONG_PROVIDER=openrouter
STRONG_CONTEXT_WINDOW=262144

# Default 티어 (검증 등 일반 작업)
DEFAULT_MODEL=deepseek/deepseek-v3.2
DEFAULT_PROVIDER=openrouter
DEFAULT_CONTEXT_WINDOW=128000

# Fast 티어 (파싱 등 경량 작업)
FAST_MODEL=qwen/qwen3.5-9b
FAST_PROVIDER=openrouter
FAST_CONTEXT_WINDOW=128000

# Purpose → Tier 매핑 (JSON, 선택사항)
# PURPOSE_TIERS={"generation":"strong","verification":"default","parsing":"fast","default":"default"}

# ── Coding Agent 모델 오버라이드 (선택사항, 티어보다 우선) ──
# CODING_GEN_MODEL=
# CODING_VERIFY_MODEL=

# ── Document AI ──
UPSTAGE_API_KEY=
LLAMA_CLOUD_API_KEY=
HF_TOKEN=

# ── Neo4j ──
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# ── LangSmith ──
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=LangGraph-Tutorial

# ── Tavily ──
TAVILY_API_KEY=

# ── Langfuse (관측성) ──
LANGFUSE_HOST=http://localhost:3100
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_TRACING_ENABLED=1
LANGFUSE_SAMPLE_RATE=1.0

# ── Application ──
ENV=local
SERVICE_NAME=youngs75-coding-ai-agent
APP_VERSION=0.1.0
DATA_DIR=./data
LOCAL_CORPUS_DIR=./data/corpus
