# ── OpenAI ──
OPENAI_API_KEY=sk-proj-...

# ── Document AI ──
UPSTAGE_API_KEY=
LLAMA_CLOUD_API_KEY=
HF_TOKEN=

# ── Neo4j ──
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# ── LangSmith ──
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=LangGraph-Tutorial

# ── Tavily ──
TAVILY_API_KEY=

# ── Langfuse (관측성) ──
LANGFUSE_HOST=http://localhost:3100
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_TRACING_ENABLED=1
LANGFUSE_SAMPLE_RATE=1.0

# ── Application ──
ENV=local
SERVICE_NAME=youngs75-coding-ai-agent
APP_VERSION=0.1.0
DATA_DIR=./data
LOCAL_CORPUS_DIR=./data/corpus
