# ═══════════════════════════════════════════════════════════════
# youngs75-coding-ai-agent 환경변수
# ═══════════════════════════════════════════════════════════════
#
# 사용법: cp .env.example .env 후 필수 항목만 입력하면 됩니다.
#

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  필수 — 프로바이더 선택 후 해당 API 키만 입력
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# 글로벌 프로바이더 (dashscope 또는 openrouter)
LLM_PROVIDER=dashscope

# ── DashScope (Qwen3 공식 API — 기본 권장) ──
# DashScope 워크스페이스 콘솔에서 발급: https://bailian.console.alibabacloud.com/
DASHSCOPE_API_KEY=sk-...
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# ── OpenRouter (대체) ──
# OpenRouter API 키 — https://openrouter.ai/keys 에서 발급
# OPENROUTER_API_KEY=sk-or-...

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  선택 — 기본값이 있으므로 수정 안 해도 됩니다
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ── 멀티티어 모델 (DashScope 기본값) ──
# LLM_PROVIDER=dashscope 시 기본 모델:
#   REASONING → qwen-max        (계획/아키텍처 설계)
#   STRONG   → qwen-coder-plus  (코드 생성/도구 호출)
#   DEFAULT  → qwen-plus        (검증/분석)
#   FAST     → qwen-turbo       (파싱/분류)
#
# LLM_PROVIDER=openrouter 시 기본 모델:
#   REASONING → qwen/qwen3-max
#   STRONG   → qwen/qwen3-coder-plus
#   DEFAULT  → qwen/qwen3-coder-next
#   FAST     → qwen/qwen3.5-flash-02-23

# 티어별 오버라이드 (필요할 때만 설정)
# REASONING_MODEL=qwen-max
# STRONG_MODEL=qwen-coder-plus
# DEFAULT_MODEL=qwen-plus
# FAST_MODEL=qwen-turbo

# ── Langfuse (관측성 — 클라우드) ──
# Langfuse Cloud: https://cloud.langfuse.com
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_TRACING_ENABLED=1
LANGFUSE_SAMPLE_RATE=1.0

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  고급 — 특정 기능 사용 시에만 필요
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# OpenAI (OpenRouter 대신 직접 사용할 때)
# OPENAI_API_KEY=sk-proj-...

# Tavily 웹 검색 (DeepResearch 에이전트)
# TAVILY_API_KEY=

# LangSmith 트레이싱
# LANGSMITH_API_KEY=
# LANGSMITH_TRACING=true
# LANGSMITH_PROJECT=LangGraph-Tutorial

# Document AI
# UPSTAGE_API_KEY=
# LLAMA_CLOUD_API_KEY=
# HF_TOKEN=

# Neo4j 그래프 DB
# NEO4J_URI=bolt://127.0.0.1:7687
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=
# NEO4J_DATABASE=neo4j

# 에이전트 고급 설정
# HOOK_CONFIG_PATH=.agent/hooks.yaml
# TOOL_PERMISSIONS_PATH=.agent/permissions.yaml
# ENABLE_PARALLEL_TOOLS=true
# COORDINATOR_MODE=false
# CODE_TOOLS_MCP_URL=http://localhost:3003/mcp/

# Coding Agent 모델 오버라이드 (티어보다 우선)
# CODING_GEN_MODEL=
# CODING_VERIFY_MODEL=

# Purpose → Tier 매핑
# PURPOSE_TIERS={"generation":"strong","verification":"default","parsing":"fast","default":"default"}

# 애플리케이션
ENV=local
SERVICE_NAME=youngs75-coding-ai-agent
APP_VERSION=0.1.0
DATA_DIR=./data
LOCAL_CORPUS_DIR=./data/corpus
