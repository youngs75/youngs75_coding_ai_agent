# ═══════════════════════════════════════════════════════════════
# youngs75-coding-ai-agent 환경변수
# ═══════════════════════════════════════════════════════════════
#
# make setup 실행 시 대화형으로 .env가 자동 생성됩니다.
# 수동 설정 시: cp .env.example .env 후 필수 항목만 입력
#

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  필수 — 프로바이더 선택 후 해당 API 키만 입력
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# 글로벌 프로바이더 (dashscope 또는 openrouter)
LLM_PROVIDER=dashscope

# ── DashScope (Qwen3 공식 API — 기본 권장) ──
# 발급: https://bailian.console.alibabacloud.com/
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# ── OpenRouter (대체) ──
# 발급: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  선택 — 기본값이 있으므로 수정 안 해도 됩니다
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ── 멀티티어 모델 (LiteLLM Gateway — 모델명에 프로바이더 접두사 포함) ──
# LLM_PROVIDER=dashscope 시 기본 모델:
#   REASONING → dashscope/qwen3-max         (계획/아키텍처 설계)
#   STRONG   → dashscope/qwen3-coder-next   (코드 생성/도구 호출)
#   DEFAULT  → dashscope/qwen3.5-plus       (검증/분석)
#   FAST     → dashscope/qwen3.5-flash      (파싱/분류)
#
# LLM_PROVIDER=openrouter 시 기본 모델:
#   REASONING → openrouter/qwen/qwen3-max
#   STRONG   → openrouter/qwen/qwen3-coder-plus
#   DEFAULT  → openrouter/qwen/qwen3-coder-next
#   FAST     → openrouter/qwen/qwen3.5-flash-02-23

# 티어별 오버라이드 (필요할 때만, LiteLLM 포맷)
# REASONING_MODEL=dashscope/qwen3-max
# STRONG_MODEL=dashscope/qwen3-coder-next
# DEFAULT_MODEL=dashscope/qwen3.5-plus
# FAST_MODEL=dashscope/qwen3.5-flash

# ── Tavily 웹 검색 (DeepResearch 에이전트) ──
# 발급: https://app.tavily.com/home
TAVILY_API_KEY=

# ── Langfuse (관측성) ──
# 발급: https://cloud.langfuse.com
# LiteLLM Proxy에서 자동 트레이싱되므로 에이전트 코드에서 별도 설정 불필요
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_TRACING_ENABLED=0

# ── LiteLLM Proxy (Docker 하니스 모드) ──
# Docker 하니스 기동 시 LiteLLM Proxy가 LLM Gateway 역할 수행
LITELLM_MASTER_KEY=sk-harness-local-dev
# Docker 외부에서 프록시 접근 시 설정 (Docker 내부는 자동)
# LITELLM_PROXY_URL=http://localhost:4000/v1

# ── MCP 서버 Workspace ──
# MCP 서버가 접근 가능한 호스트 루트 경로 (Docker 볼륨 마운트)
# youngs75-agent.sh가 현재 디렉토리를 workspace로 자동 설정
MCP_HOST_ROOT=/home

# ── Docker 컨테이너 사용자 ──
# 호스트 사용자와 일치시켜 생성 파일의 권한 문제 방지 (id -u / id -g)
HOST_UID=1000
HOST_GID=1000

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  고급 — 특정 기능 사용 시에만 필요
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Anthropic (Claude 직접 사용 시)
# ANTHROPIC_API_KEY=

# OpenAI (직접 사용 시)
# OPENAI_API_KEY=

# 에이전트 고급 설정
# HOOK_CONFIG_PATH=.agent/hooks.yaml
# TOOL_PERMISSIONS_PATH=.agent/permissions.yaml
# ENABLE_PARALLEL_TOOLS=true
# COORDINATOR_MODE=false

# 애플리케이션
ENV=local
SERVICE_NAME=youngs75-coding-ai-agent
APP_VERSION=0.1.0
DATA_DIR=./data
LOCAL_CORPUS_DIR=./data/corpus
SKILLS_DIR=./data/skills
