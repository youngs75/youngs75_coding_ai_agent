# 통합 MCP 서버 (코드 도구 + 웹/논문 검색) 컨테이너 이미지
#
# 빌드 컨텍스트: 프로젝트 루트 (..)
# 단일 서버로 코드 도구 11개 + 검색 도구 4개 = 15개 도구 제공

FROM python:3.13-slim

WORKDIR /app

RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir \
    "mcp[cli]>=1.26.0" \
    "tavily-python" \
    "arxiv" \
    "uvicorn" \
    "pydantic" \
    "httpx" \
    "python-dotenv"

# MCP 서버 런처 복사
COPY tests/run_code_tools_mcp.py /app/run_code_tools_mcp.py

# code_tools 패키지 구조
RUN mkdir -p /app/youngs75_a2a/mcp_servers/code_tools \
    && touch /app/youngs75_a2a/__init__.py \
    && touch /app/youngs75_a2a/mcp_servers/__init__.py
COPY mcp_servers/__init__.py /app/youngs75_a2a/mcp_servers/__init__.py
COPY mcp_servers/code_tools/ /app/youngs75_a2a/mcp_servers/code_tools/

ENV PYTHONPATH=/app

CMD ["python", "/app/run_code_tools_mcp.py"]
