# MCP 서버 (Tavily / arXiv / Serper) 컨테이너 이미지
#
# 빌드 컨텍스트: 프로젝트 루트 (..)
# 각 MCP 서버는 docker-compose의 command로 실행 스크립트를 지정한다.

FROM python:3.13-slim

WORKDIR /app

RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir \
    "mcp[cli]>=1.26.0" \
    "tavily-python" \
    "arxiv" \
    "uvicorn" \
    "pydantic" \
    "httpx" \
    "python-dotenv"

# MCP 서버 스크립트 복사
COPY tests/run_tavily_mcp.py /app/run_tavily_mcp.py
COPY tests/run_arxiv_mcp.py /app/run_arxiv_mcp.py
COPY tests/run_serper_mcp.py /app/run_serper_mcp.py
COPY tests/run_code_tools_mcp.py /app/run_code_tools_mcp.py

# code_tools 패키지 구조 — run_code_tools_mcp.py의 import 경로에 맞춤
RUN mkdir -p /app/youngs75_a2a/mcp_servers/code_tools \
    && touch /app/youngs75_a2a/__init__.py \
    && touch /app/youngs75_a2a/mcp_servers/__init__.py
COPY mcp_servers/__init__.py /app/youngs75_a2a/mcp_servers/__init__.py
COPY mcp_servers/code_tools/ /app/youngs75_a2a/mcp_servers/code_tools/

ENV PYTHONPATH=/app

# 기본 CMD는 docker-compose에서 오버라이드
CMD ["python", "/app/run_tavily_mcp.py"]
