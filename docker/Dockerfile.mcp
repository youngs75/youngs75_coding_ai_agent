# 통합 MCP 서버 (코드 도구 + 웹/논문 검색) 컨테이너 이미지
#
# 빌드 컨텍스트: 프로젝트 루트 (..)
# 단일 서버로 코드 도구 11개 + 검색 도구 4개 = 15개 도구 제공

FROM python:3.13-slim

WORKDIR /app

# ── 시스템 패키지 + 런타임 설치 ──
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    git \
    # Node.js 22 LTS
    && curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y nodejs \
    # Java 21 (headless)
    && apt-get install -y default-jdk-headless \
    && rm -rf /var/lib/apt/lists/*

# ── MCP 서버 + 공통 Python 패키지 ──
RUN pip install --no-cache-dir \
    "mcp[cli]>=1.26.0" \
    "tavily-python" \
    "arxiv" \
    "uvicorn" \
    "pydantic" \
    "httpx" \
    "python-dotenv" \
    # 사용자 프로젝트에서 자주 사용하는 패키지
    "pytest" \
    "fastapi" \
    "flask" \
    "sqlalchemy" \
    "requests" \
    "aiohttp"

# MCP 서버 런처 복사
COPY tests/run_code_tools_mcp.py /app/run_code_tools_mcp.py

# code_tools 패키지 구조
COPY coding_agent/__init__.py /app/coding_agent/__init__.py
COPY coding_agent/mcp_servers/ /app/coding_agent/mcp_servers/

ENV PYTHONPATH=/app

CMD ["python", "/app/run_code_tools_mcp.py"]
