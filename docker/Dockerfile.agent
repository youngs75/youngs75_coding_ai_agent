# A2A 에이전트 서버 컨테이너 이미지
#
# 빌드 컨텍스트: 프로젝트 루트 (..)
# pyproject.toml의 package-dir 매핑으로 youngs75_a2a.* 네임스페이스를 구성한다.

FROM python:3.13-slim

WORKDIR /app

RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*

# uv 설치 — 빠른 패키지 관리자
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

# 프로젝트 메타데이터 복사 후 의존성 설치
COPY pyproject.toml uv.lock /app/

# 소스 코드 복사 (pyproject.toml의 package-dir 매핑에 맞추어 배치)
COPY __init__.py /app/
COPY core/ /app/core/
COPY agents/ /app/agents/
COPY a2a_local/ /app/a2a_local/
COPY mcp_servers/ /app/mcp_servers/
COPY cli/ /app/cli/
COPY utils/ /app/utils/
COPY scripts/ /app/scripts/
COPY eval_pipeline/ /app/eval_pipeline/
COPY tests/ /app/tests/

# editable 모드 설치 — youngs75_a2a.* 패키지 매핑 활성화
RUN uv pip install --system -e .

ENV PYTHONPATH=/app
EXPOSE 18080

CMD ["python", "-m", "youngs75_a2a.tests.run_agent_server"]
