# 평가 파이프라인 컨테이너 이미지
#
# 빌드 컨텍스트: 프로젝트 루트 (..)
# 실행 후 종료되는 일회성 컨테이너

FROM python:3.13-slim

WORKDIR /app

RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*

# uv 설치 — 빠른 패키지 관리자
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

# 프로젝트 메타데이터 복사
COPY pyproject.toml uv.lock /app/

# 소스 코드 복사
COPY __init__.py /app/
COPY core/ /app/core/
COPY agents/ /app/agents/
COPY a2a_local/ /app/a2a_local/
COPY mcp_servers/ /app/mcp_servers/
COPY cli/ /app/cli/
COPY utils/ /app/utils/
COPY scripts/ /app/scripts/
COPY eval_pipeline/ /app/eval_pipeline/
COPY tests/ /app/tests/

# editable 모드 설치 + 개발 의존성 (deepeval 포함)
RUN uv pip install --system -e ".[dev]" 2>/dev/null || uv pip install --system -e .
# deepeval 별도 설치 (dev dependency-group에 있으므로)
RUN pip install --no-cache-dir "deepeval>=3.8,<4"

ENV PYTHONPATH=/app
ENV DATA_DIR=/app/data
ENV LOCAL_CORPUS_DIR=/app/data/corpus

ENTRYPOINT ["python", "-m", "youngs75_a2a.scripts.run_pipeline"]
CMD ["--all", "--skip-review"]
