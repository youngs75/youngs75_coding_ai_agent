FROM python:3.13-slim

WORKDIR /app

RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*

# 평가 파이프라인 의존성 설치
RUN pip install --no-cache-dir \
    "deepeval>=3.8,<4" \
    "langchain>=1.2.0" \
    "langchain-openai>=1.1.0" \
    "langfuse>=4.0.6" \
    "langgraph>=1.1.0" \
    "pydantic>=2.7,<3" \
    "pydantic-settings>=2.2,<3" \
    "python-dotenv>=1.2.0" \
    "structlog>=25,<26" \
    "httpx"

# youngs75_a2a 패키지 복사 (data/ 포함)
COPY youngs75_a2a/ /app/youngs75_a2a/

ENV PYTHONPATH=/app
ENV DATA_DIR=/app/youngs75_a2a/data
ENV LOCAL_CORPUS_DIR=/app/youngs75_a2a/data/corpus

ENTRYPOINT ["python", "-m", "youngs75_a2a.scripts.run_pipeline"]
CMD ["--all", "--skip-review"]
