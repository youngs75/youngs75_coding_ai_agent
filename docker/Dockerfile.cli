# CLI 대화형 에이전트 인터페이스용 Dockerfile
#
# 빌드 컨텍스트: 프로젝트 루트 (..)
# 사용법:
#   docker compose -f docker/docker-compose.yml run --rm cli
#   docker compose -f docker/docker-compose.yml run --rm cli youngs75-agent

FROM python:3.13-slim

WORKDIR /app

# 시스템 의존성 설치 (curl: 헬스체크)
RUN apt-get update && apt-get install -y --no-install-recommends \
        curl \
    && rm -rf /var/lib/apt/lists/*

# uv 설치 — 빠른 파이썬 패키지 관리자
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

# 프로젝트 메타데이터 복사
COPY pyproject.toml uv.lock /app/

# 소스 코드 복사 (pyproject.toml의 package-dir 매핑에 맞추어 배치)
COPY __init__.py /app/
COPY core/ /app/core/
COPY agents/ /app/agents/
COPY a2a_local/ /app/a2a_local/
COPY mcp_servers/ /app/mcp_servers/
COPY cli/ /app/cli/
COPY utils/ /app/utils/
COPY scripts/ /app/scripts/
COPY eval_pipeline/ /app/eval_pipeline/
COPY tests/ /app/tests/

# editable 모드 설치 — CLI 엔트리포인트(youngs75-agent) 등록
RUN uv pip install --system -e .

ENV PYTHONPATH=/app
# 대화형 모드를 위해 버퍼링 비활성화
ENV PYTHONUNBUFFERED=1

# youngs75-agent CLI 엔트리포인트 실행
ENTRYPOINT ["youngs75-agent"]
