# ═══════════════════════════════════════════════════════════════
# 개발 환경 설정 (Development)
# ═══════════════════════════════════════════════════════════════
# 로컬 개발 시 사용하는 설정.
# docker/docker-compose.yml의 env_file로 지정하거나,
# `source config/settings.dev.env` 후 직접 실행할 수 있다.
#
# 주의: 실제 API 키는 이 파일에 넣지 말 것.
#       시크릿은 .env 파일 또는 환경변수로 별도 관리한다.
# ═══════════════════════════════════════════════════════════════

# ── 런타임 식별 ──
ENV=local
SERVICE_NAME=youngs75-a2a
APP_VERSION=0.1.0-dev

# ── LLM 모델 설정 ──
# 개발 시에는 비용이 낮은 소형 모델 사용
MODEL_PROVIDER=openai
MODEL_NAME=gpt-4o-mini
DEFAULT_MODEL=gpt-4o-mini
OPENAI_MODEL_NAME=gpt-4o-mini
TEMPERATURE=0.1

# API 키 — 플레이스홀더 (실제 값은 .env에 설정)
OPENROUTER_API_KEY=<your-openrouter-api-key>
OPENAI_API_KEY=<your-openai-api-key>

# ── MCP 서버 (로컬 컨테이너) ──
TAVILY_MCP_URL=http://localhost:3001/mcp/
ARXIV_MCP_URL=http://localhost:3000/mcp/
SERPER_MCP_URL=http://localhost:3002/mcp/

# ── Agent 서버 (로컬 컨테이너) ──
SIMPLE_REACT_URL=http://localhost:18081
DEEP_RESEARCH_URL=http://localhost:18082
DEEP_RESEARCH_A2A_URL=http://localhost:18083

# ── Langfuse (관측성) ──
# 개발 환경에서는 로컬 Langfuse 인스턴스 사용 또는 비활성화
LANGFUSE_TRACING_ENABLED=false
LANGFUSE_HOST=http://localhost:3100
LANGFUSE_PUBLIC_KEY=<your-langfuse-public-key>
LANGFUSE_SECRET_KEY=<your-langfuse-secret-key>
LANGFUSE_SAMPLE_RATE=1.0

# ── LangSmith 트레이싱 ──
# 개발 시에는 비활성화
LANGCHAIN_TRACING_V2=false

# ── 디버그 모드 ──
LOG_LEVEL=DEBUG
