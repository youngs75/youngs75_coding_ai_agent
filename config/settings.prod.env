# ═══════════════════════════════════════════════════════════════
# 프로덕션 환경 설정 (Production)
# ═══════════════════════════════════════════════════════════════
# 실제 서비스 운영 환경 설정.
# 최적화된 모델, Langfuse 관측성 활성화, 샘플링 적용.
#
# 주의: 실제 API 키는 이 파일에 넣지 말 것.
#       시크릿은 CI/CD secrets 또는 Kubernetes secrets로 관리한다.
# ═══════════════════════════════════════════════════════════════

# ── 런타임 식별 ──
ENV=production
SERVICE_NAME=youngs75-a2a
APP_VERSION=0.1.0

# ── LLM 모델 설정 ──
# 프로덕션에서는 최적의 성능을 위해 상위 모델 사용
MODEL_PROVIDER=openai
MODEL_NAME=gpt-5.4
DEFAULT_MODEL=gpt-5.4
OPENAI_MODEL_NAME=gpt-5.4
TEMPERATURE=0.0

# API 키 — 플레이스홀더 (Kubernetes secrets / CI/CD secrets에서 주입)
OPENROUTER_API_KEY=<injected-from-secrets>
OPENAI_API_KEY=<injected-from-secrets>

# ── MCP 서버 (Docker 네트워크 내부 또는 외부 엔드포인트) ──
TAVILY_MCP_URL=http://mcp-tavily:3001/mcp/
ARXIV_MCP_URL=http://mcp-arxiv:3000/mcp/
SERPER_MCP_URL=http://mcp-serper:3002/mcp/

# ── Agent 서버 (Docker 네트워크 내부) ──
SIMPLE_REACT_URL=http://agent-simple-react:18081
DEEP_RESEARCH_URL=http://agent-deep-research:18082
DEEP_RESEARCH_A2A_URL=http://agent-deep-research-a2a:18083

# ── Langfuse (관측성) ──
# 프로덕션에서는 Langfuse 활성화, 비용 절감을 위해 50% 샘플링
LANGFUSE_TRACING_ENABLED=true
LANGFUSE_HOST=<your-production-langfuse-host>
LANGFUSE_PUBLIC_KEY=<injected-from-secrets>
LANGFUSE_SECRET_KEY=<injected-from-secrets>
LANGFUSE_SAMPLE_RATE=0.5

# ── LangSmith 트레이싱 ──
LANGCHAIN_TRACING_V2=false

# ── 로그 레벨 ──
# 프로덕션에서는 불필요한 로그 최소화
LOG_LEVEL=WARNING
